# OKO TRAVELS API - Configuración de Variables de Entorno

# Puerto
PORT=3000

# Entorno
NODE_ENV=production

# MongoDB URI (MongoDB Atlas)
# Obtén una URL en: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/oko-travels

# Cloudinary (para cargar imágenes)
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT Secret (para autenticación)
JWT_SECRET=tu-secreto-muy-seguro-aqui

# Email (para notificaciones)
EMAIL_USER=tu-email@gmail.com
EMAIL_PASSWORD=tu-contraseña-app

# Stripe (para pagos)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
